	<!-- Default mapping for css and js and img folders  -->
	<servlet-mapping>
    <servlet-name>default</servlet-name>
    <url-pattern>/images/*</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
    <servlet-name>default</servlet-name>
    <url-pattern>/css/*</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
    <servlet-name>default</servlet-name>
    <url-pattern>/js/*</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
    <servlet-name>default</servlet-name>
    <url-pattern>/fonts/*</url-pattern>
	</servlet-mapping>
	<servlet-mapping>
    <servlet-name>default</servlet-name>
    <url-pattern>/pdf/*</url-pattern>
	</servlet-mapping>
	
	<servlet-mapping>
    <servlet-name>default</servlet-name>
    <url-pattern>/uploadedFiles/*</url-pattern>
	</servlet-mapping>
	
	<session-config>
    <session-timeout>20</session-timeout>
</session-config>
	
	
	

	
	
	
	
	<mime-mapping>
    <extension>manifest</extension>
    <mime-type>text/cache-manifest</mime-type>
</mime-mapping>


   
    <servlet>
    <servlet-name>CaptchaServlet</servlet-name>
    <servlet-class>in.ts.icad.leagal.util.CaptchaGenServlet</servlet-class>
   
  </servlet>
  <servlet-mapping>
    <servlet-name>CaptchaServlet</servlet-name>
    <url-pattern>/captcha.jpg</url-pattern>
  </servlet-mapping>
  
  
      <servlet>
    <servlet-name>CaptchaServlet2</servlet-name>
    <servlet-class>in.ts.icad.leagal.util.CaptchaGenServlet2</servlet-class>
   
  </servlet>
  <servlet-mapping>
    <servlet-name>CaptchaServlet2</servlet-name>
    <url-pattern>/captcha2.jpg</url-pattern>
  </servlet-mapping>
  
  
   <servlet>
    <servlet-name>CaptchaServlet3</servlet-name>
    <servlet-class>in.ts.icad.leagal.util.CaptchaGenServlet3</servlet-class>
   
  </servlet>
  <servlet-mapping>
    <servlet-name>CaptchaServlet3</servlet-name>
    <url-pattern>/captcha3.jpg</url-pattern>
  </servlet-mapping>
  
  
  

   
   <filter>
	<filter-name>MySessionFilter</filter-name>
	<filter-class>
		in.ts.icad.leagal.util.MySessionFilter
	</filter-class>
	<init-param>
		<param-name>avoid-urls</param-name>
		<param-value>/web/home</param-value>
	</init-param>
</filter>
<filter-mapping>
	<filter-name>MySessionFilter</filter-name>
	<url-pattern>/*</url-pattern>
</filter-mapping>

<filter>
      <filter-name>AddHeaderFilter</filter-name>
      <filter-class>in.ts.icad.leagal.util.AddHeaderFilter</filter-class>
   
    </filter>

    <filter-mapping>
      <filter-name>AddHeaderFilter</filter-name>
      <url-pattern>/*</url-pattern>
    </filter-mapping>
    
    
    
    
    
        <filter>
        <filter-name>CORSFilter</filter-name>
        <filter-class>in.ts.icad.leagal.util.CORSFilter</filter-class> <!-- your package name and filter class -->
    </filter>
    <filter-mapping>
        <filter-name>CORSFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping> 
    
    
    <listener>
    <listener-class>in.ts.icad.leagal.util.MyHttpSessionListener</listener-class>
</listener>
 
